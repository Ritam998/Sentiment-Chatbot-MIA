@app.post("/analyze", response_model=SentimentResponse)
async def analyze_sentiment(req: AnalyzeRequest):
    text = req.text.strip()
    if not text:
        raise HTTPException(status_code=400, detail="Text cannot be empty")
    if len(text) > 5000:
        raise HTTPException(status_code=400, detail="Text too long (max 5000 chars)")
    
    model_used = "rule-based"
    
    # Try transformer model first
    if req.use_ml and transformer_model:
        try:
            results = transformer_model(text[:512])  # BERT max tokens
            scores_raw = results[0]
            
            pos_score = next((s["score"] for s in scores_raw if s["label"] == "POSITIVE"), 0.5)
            neg_score = next((s["score"] for s in scores_raw if s["label"] == "NEGATIVE"), 0.5)
            neu_score = max(0, 1 - pos_score - neg_score)
            
            # Normalize
            total = pos_score + neg_score + neu_score
            pos_score /= total
            neg_score /= total
            neu_score /= total
            
            if pos_score > 0.6:
                sentiment = "POSITIVE"
            elif neg_score > 0.6:
                sentiment = "NEGATIVE"
            elif pos_score > 0.35 and neg_score > 0.35:
                sentiment = "MIXED"
            else:
                sentiment = "NEUTRAL"
            
            confidence = max(pos_score, neg_score, neu_score)
            model_used = "DistilBERT (SST-2)"
            
        except Exception as e:
            print(f"Transformer inference failed: {e}, falling back to rule-based")
            result = rule_based_sentiment(text)
            sentiment = result["label"]
            pos_score = result["pos"]
            neg_score = result["neg"]
            neu_score = result["neu"]
            confidence = result["score"]
    else:
        result = rule_based_sentiment(text)
        sentiment = result["label"]
        pos_score = result["pos"]
        neg_score = result["neg"]
        neu_score = result["neu"]
        confidence = result["score"]
    
    scores = {
        "positive": round(pos_score, 4),
        "negative": round(neg_score, 4),
        "neutral": round(neu_score, 4)
    }
    
    emotions = detect_emotions(text)
    keywords = extract_keywords(text)
    tone = detect_tone(text, sentiment)
    explanation = generate_explanation(text, sentiment, scores, emotions, keywords)
    
    return SentimentResponse(
        sentiment=sentiment.capitalize(),
        scores=scores,
        explanation=explanation,
        keywords=keywords,
        emotions=emotions,
        tone=tone,
        model_used=model_used,
        confidence=round(confidence, 4),
        timestamp=datetime.utcnow().isoformat()
    )
 
@app.post("/batch")
async def batch_analyze(texts: list[str]):
    """Analyze multiple texts at once"""
    if len(texts) > 20:
        raise HTTPException(status_code=400, detail="Max 20 texts per batch")
    
    results = []
    for text in texts:
        req = AnalyzeRequest(text=text)
        result = await analyze_sentiment(req)
        results.append(result)
    return results
 
