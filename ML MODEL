def rule_based_sentiment(text: str) -> dict:
    """Rule-based sentiment analysis with negation handling"""
    tokens = re.findall(r"\b\w+\b", text.lower())
    
    pos_score = 0.0
    neg_score = 0.0
    negated = False
    intensity = 1.0
    
    for i, token in enumerate(tokens):
        if token in NEGATION_WORDS:
            negated = True
            continue
        if token in INTENSIFIERS:
            intensity = INTENSIFIERS[token]
            continue
            
        if token in POSITIVE_WORDS:
            score = 1.0 * intensity
            if negated:
                neg_score += score
            else:
                pos_score += score
            negated = False
            intensity = 1.0
        elif token in NEGATIVE_WORDS:
            score = 1.0 * intensity
            if negated:
                pos_score += score
            else:
                neg_score += score
            negated = False
            intensity = 1.0
        else:
            if i > 0:
                negated = False
                intensity = 1.0
    
    total = pos_score + neg_score + 0.01
    pos_pct = pos_score / total
    neg_pct = neg_score / total
    
    # Normalize to [0,1]
    pos_norm = min(pos_pct, 1.0)
    neg_norm = min(neg_pct, 1.0)
    neu_norm = max(0.0, 1.0 - pos_norm - neg_norm)
    
    # Normalize to sum to 1
    total_norm = pos_norm + neg_norm + neu_norm
    pos_final = pos_norm / total_norm
    neg_final = neg_norm / total_norm
    neu_final = neu_norm / total_norm
    
    if pos_final > 0.55:
        label = "POSITIVE"
    elif neg_final > 0.55:
        label = "NEGATIVE"
    elif pos_final > 0.3 and neg_final > 0.3:
        label = "MIXED"
    else:
        label = "NEUTRAL"
    
    conf = max(pos_final, neg_final, neu_final)
    
    return {
        "label": label,
        "score": conf,
        "pos": pos_final,
        "neg": neg_final,
        "neu": neu_final
    }
 
def detect_emotions(text: str) -> list[str]:
    """Detect up to 3 primary emotions from text"""
    text_lower = text.lower()
    scores = {}
    for emotion, words in EMOTION_LEXICON.items():
        count = sum(1 for w in words if w in text_lower)
        if count > 0:
            scores[emotion] = count
    
    sorted_emotions = sorted(scores.items(), key=lambda x: -x[1])
    return [e[0] for e in sorted_emotions[:3]]
 
def extract_keywords(text: str) -> list[str]:
    """Extract emotionally significant keywords"""
    tokens = re.findall(r"\b\w+\b", text.lower())
    keywords = []
    for token in tokens:
        if token in POSITIVE_WORDS or token in NEGATIVE_WORDS:
            if token not in keywords:
                keywords.append(token)
    return keywords[:5]
 
def detect_tone(text: str, sentiment: str) -> str:
    """Detect writing tone"""
    text_lower = text.lower()
    
    # Sarcasm indicators
    if re.search(r"(yeah right|sure|totally|obviously|clearly).*(not|never)|(\.\.\.|!!!)", text_lower):
        return "sarcastic"
    
    if "!" in text and sentiment == "POSITIVE":
        return "enthusiastic"
    if "?" in text:
        return "questioning"
    if sentiment == "NEGATIVE" and any(w in text_lower for w in ["disappointed", "expected", "hoped"]):
        return "disappointed"
    if sentiment == "POSITIVE" and any(w in text_lower for w in ["thank", "grateful", "appreciate"]):
        return "grateful"
    if any(w in text_lower for w in ["worried", "nervous", "anxious", "concerned"]):
        return "anxious"
    if sentiment == "NEGATIVE" and any(w in text_lower for w in ["angry", "furious", "hate", "worst"]):
        return "angry"
    if sentiment == "POSITIVE":
        return "positive"
    if sentiment == "NEGATIVE":
        return "critical"
    return "neutral"
 
def generate_explanation(text: str, sentiment: str, scores: dict, emotions: list, keywords: list) -> str:
    """Generate a human-readable explanation"""
    sent_lower = sentiment.lower()
    
    if keywords:
        kw_str = ", ".join(f'"{k}"' for k in keywords[:2])
        base = f"The text carries a {sent_lower} sentiment, driven by words like {kw_str}."
    else:
        base = f"The text carries a {sent_lower} sentiment overall."
    
    if emotions:
        emo_str = " and ".join(emotions[:2])
        base += f" Dominant emotions detected: {emo_str}."
    
    if sentiment == "MIXED":
        base += " The text contains both positive and negative signals, suggesting a nuanced or conflicted viewpoint."
    elif sentiment == "NEUTRAL":
        base += " The language is largely factual and objective, without strong emotional markers."
    
    return base
 

