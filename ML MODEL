transformer_model = None
transformer_tokenizer = None
 
def load_transformer_model():
    """Load HuggingFace transformer model (lazy load)"""
    global transformer_model, transformer_tokenizer
    try:
        from transformers import pipeline, AutoTokenizer, AutoModelForSequenceClassification
        print("Loading DistilBERT sentiment model...")
        transformer_tokenizer = AutoTokenizer.from_pretrained(
            "distilbert-base-uncased-finetuned-sst-2-english"
        )
        transformer_model = pipeline(
            "sentiment-analysis",
            model="distilbert-base-uncased-finetuned-sst-2-english",
            tokenizer=transformer_tokenizer,
            return_all_scores=True,
        )
        print("Model loaded successfully!")
        return True
    except Exception as e:
        print(f"Transformer load failed: {e}. Using rule-based fallback.")
        return False
 

 
